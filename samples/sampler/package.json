{
  "name": "limestone-sampler",
  "version": "1.9.0",
  "description": "Component and QA samples for Limestone",
  "private": true,
  "main": "index.js",
  "scripts": {
    "bootstrap": "enact bootstrap",
    "clean": "enact clean",
    "cleanall": "enact clean --all",
    "lint": "enact lint --strict",
    "test": "echo \"No test suite\" && exit 0",
    "pack": "storybook build -c .storybook -o dist",
    "pack-qa": "storybook build -c .qa-storybook -o dist",
    "serve": "storybook dev -p 8080 -c .storybook --ci",
    "serve-qa": "storybook dev -p 8080 -c .qa-storybook --ci"
  },
  "license": "Apache-2.0",
  "enact": {
    "theme": "limestone"
  },
  "dependencies": {
    "@enact/core": "^5.4.2",
    "@enact/i18n": "^5.4.2",
    "@enact/limestone": "../../",
    "@enact/spotlight": "^5.4.2",
    "@enact/storybook-utils": "^7.0.2",
    "@enact/ui": "^5.4.2",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/react-webpack5": "^10.2.10",
    "classnames": "^2.5.1",
    "ilib": "^14.21.2",
    "react": "~19.0.3",
    "react-dom": "~19.0.3",
    "react-ga4": "^2.1.0",
    "storybook": "^10.2.10"
  }
}
