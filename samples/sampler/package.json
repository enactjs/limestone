{
  "name": "limestone-sampler",
  "version": "1.10.1",
  "description": "Component and QA samples for Limestone",
  "private": true,
  "main": "index.js",
  "scripts": {
    "bootstrap": "enact bootstrap",
    "clean": "enact clean",
    "cleanall": "enact clean --all",
    "lint": "enact lint --strict",
    "test": "echo \"No test suite\" && exit 0",
    "pack": "storybook build -c .storybook -o dist",
    "pack-qa": "storybook build -c .qa-storybook -o dist",
    "serve": "storybook dev -p 8080 -c .storybook --ci",
    "serve-qa": "storybook dev -p 8080 -c .qa-storybook --ci"
  },
  "license": "Apache-2.0",
  "enact": {
    "theme": "limestone"
  },
  "dependencies": {
    "@enact/core": "^5.5.1",
    "@enact/i18n": "^5.5.1",
    "@enact/limestone": "../../",
    "@enact/spotlight": "^5.5.1",
    "@enact/storybook-utils": "^8.0.0",
    "@enact/ui": "^5.5.1",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@storybook/react-webpack5": "^10.3.6",
    "classnames": "^2.5.1",
    "ilib": "^14.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.6",
    "react-ga4": "^2.1.0",
    "storybook": "^10.3.6"
  }
}
